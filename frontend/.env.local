# Environment variables for SentinelSight frontend
# Copy this file to .env.local and update values

# Backend API URL (required)
# Local development: http://localhost:8000
# Render production: https://sentinelsight-api.onrender.com
# Custom VPS: https://your-api-domain.com
NEXT_PUBLIC_API_URL=https://nettracepro.onrender.com

# Optional: API rate limiting info (display-only, not used in app)
# NEXT_PUBLIC_RATE_LIMIT_PER_MINUTE=50
